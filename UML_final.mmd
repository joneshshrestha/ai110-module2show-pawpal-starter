        +remove_task(task_id: String): void
    }

    class CareTask {
        +task_id: String
        +title: String
        +category: String
        +duration_minutes: int
        +priority: int
        +preferred_window: String?
        +is_required: bool
        +frequency: String
        +due_date: date?
        +scheduled_time: String?
        +is_completed: bool
        +pet_name: String?
        +update_task(...): void
        +fits_window(window: String): bool
        +priority_score(): float
        +mark_complete(): void
        +recurrence_delta(): timedelta?
    }

    class DailyScheduler {
        +owner_profile: OwnerProfile
        +tasks: List~CareTask~
        +pet: Pet?
        +last_generated_plan: List~CareTask~
