        -_attach_task_to_source(source_task: CareTask, new_task: CareTask): void
        +complete_task(task_id: String, completed_on: date?): CareTask?
        -_parse_hhmm(value: String): Tuple~int,int~
        +filter_tasks(is_completed: bool?, pet_name: String?, tasks: List~CareTask~?): List~CareTask~
        +generate_plan(): List~CareTask~
        +sort_by_time(tasks: List~CareTask~?): List~CareTask~
        +detect_time_conflicts(tasks: List~CareTask~?): List~String~
        +explain_plan(): String
        +get_unscheduled_tasks(): List~CareTask~
    }

    OwnerProfile "1" *-- "0..*" Pet : owns
    Pet "1" *-- "0..*" CareTask : has
    DailyScheduler "1" --> "1" OwnerProfile : uses
    DailyScheduler "1" --> "0..1" Pet : optional context
