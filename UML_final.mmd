        +set_time_preferences(windows: List~String~): void
        +add_pet(pet: Pet): void
        +remove_pet(pet_name: String): void
        +get_all_tasks(): List~CareTask~
    }

    class Pet {
        +name: String
        +species: String
        +age: int
        +care_notes: String
        +tasks: List~CareTask~
